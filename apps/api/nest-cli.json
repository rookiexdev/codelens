{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "../prisma/generated/client/**/*",
        "exclude": "../prisma/generated/client/**/*.ts",
        "outDir": "dist/prisma",
        "watchAssets": true
      }
    ]
  }
}
